#!/usr/bin/env bash
# This script configures localhost to resolve to 127.0.0.2 and facebook.com to resolve to 8.8.8.8

# Remove existing entries and add new ones
sed -i '/localhost/d' /etc/hosts
sed -i '/facebook.com/d' /etc/hosts
cat >> /etc/hosts << EOF
127.0.0.2 localhost
8.8.8.8 facebook.com
EOF
